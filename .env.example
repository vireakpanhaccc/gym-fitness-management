# Copy this file to .env and fill in your own values.
# Used by docker-compose.yaml for ${MONGO_URI} and ${JWT_SECRET}.

# Your MongoDB Atlas connection string (the same value the services read as `uri`).
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Shared secret used to sign (identity-service) and verify (api-gateway) JWTs.
# It MUST be identical for both or token verification will fail.
JWT_SECRET=change_me_to_a_long_random_string
