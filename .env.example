# =============================================================
# Copy this file to ".env" and fill in real values.
# docker-compose auto-loads the root ".env" for ${...} below.
# (.env is gitignored — never commit real secrets.)
# =============================================================

# ---- Shared by ALL services ----
# MongoDB Atlas connection string (one shared cloud database).
uri=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gym?retryWrites=true&w=majority

# Secret used to sign (identity-service) and verify (api-gateway) JWTs.
# These two MUST match. Use a long random string.
JWT_SECRET=change_me_to_a_long_random_string

# =============================================================
# Per-service env (already wired in docker-compose.yaml).
# Only needed manually when running a service standalone
# (`node index.js`) or on its own EC2 instance.
# =============================================================
#
# identity-service:   PORT=4001  uri=...  JWT_SECRET=...
# member-service:     PORT=4002  uri=...
# membership-service: PORT=4003  uri=...
# trainer-service:    PORT=4004  uri=...
# workout-service:    PORT=4005  uri=...
# attendance-service: PORT=4006  uri=...
#
# api-gateway:        PORT=8080  JWT_SECRET=...
#   IDENTITY_URL=http://identity-service:4001
#   MEMBER_URL=http://member-service:4002
#   MEMBERSHIP_URL=http://membership-service:4003
#   TRAINER_URL=http://trainer-service:4004
#   WORKOUT_URL=http://workout-service:4005
#   ATTENDANCE_URL=http://attendance-service:4006
#   (On EC2, replace the hostnames with each instance's private IP/DNS.)
